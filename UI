local GzusUI = {
    Version = "1.0.1", -- อัปเดตเวอร์ชัน
    Theme = {
        Background = Color3.fromRGB(20, 20, 20),      
        Secondary = Color3.fromRGB(25, 25, 25),       
        Stroke = Color3.fromRGB(45, 45, 45),          
        Text = Color3.fromRGB(255, 255, 255),         
        TextMuted = Color3.fromRGB(150, 150, 150),    
        Accent = Color3.fromRGB(0, 170, 255),         
        CloseHover = Color3.fromRGB(255, 75, 75),     -- สีแดงตอนชี้ปุ่มปิด
        ButtonHover = Color3.fromRGB(40, 40, 40),     -- สีเทาตอนชี้ปุ่มพับจอ
        Font = Font.new("rbxasset://fonts/families/GothamSSm.json", Enum.FontWeight.Medium, Enum.FontStyle.Normal)
    }
}

-- [ 🌟 Services ] --------------------------------------------------------
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local SafeParent = gethui and gethui() or CoreGui

-- [ 🌟 Core Utilities ] --------------------------------------------------
function GzusUI:Tween(Object, Properties, Duration, Style, Direction)
    Duration = Duration or 0.4
    Style = Style or Enum.EasingStyle.Quint
    Direction = Direction or Enum.EasingDirection.Out
    
    local TweenInfo = TweenInfo.new(Duration, Style, Direction)
    local Tween = TweenService:Create(Object, TweenInfo, Properties)
    Tween:Play()
    return Tween
end

-- [ 🌟 API: CreateWindow ] -----------------------------------------------
function GzusUI:CreateWindow(Config)
    local Window = {}
    
    Config.Title = Config.Title or "GzusUI Library"
    Config.SubTitle = Config.SubTitle or "by Gzus"
    Config.Size = Config.Size or UDim2.fromOffset(600, 400)
    Config.ToggleKey = Config.ToggleKey or Enum.KeyCode.RightControl -- ปุ่มซ่อน UI เริ่มต้น
    
    -- 1. สร้าง ScreenGui หลัก
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "Gzus_Interface"
    ScreenGui.Parent = SafeParent
    ScreenGui.ResetOnSpawn = false
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Global

    -- 2. สร้างกรอบหน้าต่างหลัก (Main Frame)
    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Size = Config.Size
    MainFrame.Position = UDim2.new(0.5, -Config.Size.X.Offset/2, 0.5, -Config.Size.Y.Offset/2)
    MainFrame.BackgroundColor3 = GzusUI.Theme.Background
    MainFrame.BorderSizePixel = 0
    MainFrame.Parent = ScreenGui
    MainFrame.ClipsDescendants = true 

    local MainCorner = Instance.new("UICorner")
    MainCorner.CornerRadius = UDim.new(0, 8)
    MainCorner.Parent = MainFrame

    local MainStroke = Instance.new("UIStroke")
    MainStroke.Color = GzusUI.Theme.Stroke
    MainStroke.Thickness = 1
    MainStroke.Parent = MainFrame
    
    local Shadow = Instance.new("ImageLabel")
    Shadow.Name = "DropShadow"
    Shadow.AnchorPoint = Vector2.new(0.5, 0.5)
    Shadow.Position = UDim2.new(0.5, 0, 0.5, 0)
    Shadow.Size = UDim2.new(1, 47, 1, 47) 
    Shadow.BackgroundTransparency = 1
    Shadow.Image = "rbxassetid://6015897843"
    Shadow.ImageColor3 = Color3.fromRGB(0, 0, 0)
    Shadow.ImageTransparency = 0.4
    Shadow.SliceCenter = Rect.new(49, 49, 450, 450)
    Shadow.ZIndex = -1
    Shadow.Parent = MainFrame

    -- 3. สร้าง Topbar
    local Topbar = Instance.new("Frame")
    Topbar.Name = "Topbar"
    Topbar.Size = UDim2.new(1, 0, 0, 45)
    Topbar.BackgroundTransparency = 1
    Topbar.Parent = MainFrame

    local TitleInfo = Instance.new("Frame")
    TitleInfo.Name = "TitleInfo"
    TitleInfo.Size = UDim2.new(0.7, 0, 1, 0)
    TitleInfo.BackgroundTransparency = 1
    TitleInfo.Parent = Topbar

    local TitleLabel = Instance.new("TextLabel")
    TitleLabel.Name = "Title"
    TitleLabel.Size = UDim2.new(0, 0, 1, 0)
    TitleLabel.BackgroundTransparency = 1
    TitleLabel.Text = Config.Title
    TitleLabel.TextColor3 = GzusUI.Theme.Text
    TitleLabel.FontFace = GzusUI.Theme.Font
    TitleLabel.TextSize = 16
    TitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    TitleLabel.AutomaticSize = Enum.AutomaticSize.X 
    TitleLabel.Parent = TitleInfo

    local SubTitleLabel = Instance.new("TextLabel")
    SubTitleLabel.Name = "SubTitle"
    SubTitleLabel.Size = UDim2.new(0, 0, 1, 0)
    SubTitleLabel.BackgroundTransparency = 1
    SubTitleLabel.Text = "  |  " .. Config.SubTitle
    SubTitleLabel.TextColor3 = GzusUI.Theme.TextMuted
    SubTitleLabel.FontFace = GzusUI.Theme.Font
    SubTitleLabel.TextSize = 14
    SubTitleLabel.TextXAlignment = Enum.TextXAlignment.Left
    SubTitleLabel.AutomaticSize = Enum.AutomaticSize.X
    SubTitleLabel.Parent = TitleInfo
    
    local TopbarLayout = Instance.new("UIListLayout")
    TopbarLayout.FillDirection = Enum.FillDirection.Horizontal
    TopbarLayout.SortOrder = Enum.SortOrder.LayoutOrder
    TopbarLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    TopbarLayout.Parent = TitleInfo
    
    local TopbarPadding = Instance.new("UIPadding")
    TopbarPadding.PaddingLeft = UDim.new(0, 15)
    TopbarPadding.Parent = TitleInfo

    local TopbarDivider = Instance.new("Frame")
    TopbarDivider.Name = "Divider"
    TopbarDivider.Size = UDim2.new(1, 0, 0, 1)
    TopbarDivider.Position = UDim2.new(0, 0, 1, -1)
    TopbarDivider.BackgroundColor3 = GzusUI.Theme.Stroke
    TopbarDivider.BorderSizePixel = 0
    TopbarDivider.Parent = Topbar

    -- ==========================================
    -- 🚀 4. ระบบ Window Controls (พับจอ / ปิด)
    -- ==========================================
    local WindowControls = Instance.new("Frame")
    WindowControls.Name = "WindowControls"
    WindowControls.Size = UDim2.new(0, 100, 1, 0)
    WindowControls.Position = UDim2.new(1, -100, 0, 0)
    WindowControls.BackgroundTransparency = 1
    WindowControls.Parent = Topbar

    local ControlsLayout = Instance.new("UIListLayout")
    ControlsLayout.FillDirection = Enum.FillDirection.Horizontal
    ControlsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    ControlsLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ControlsLayout.Parent = WindowControls

    -- 🔴 ปุ่มปิด (Close Button)
    local CloseBtn = Instance.new("TextButton")
    CloseBtn.Name = "Close"
    CloseBtn.Size = UDim2.new(0, 45, 1, -1) -- หักเส้นขอบล่างออกนิดนึง
    CloseBtn.BackgroundTransparency = 1
    CloseBtn.BackgroundColor3 = GzusUI.Theme.CloseHover
    CloseBtn.Text = "✕"
    CloseBtn.TextColor3 = GzusUI.Theme.TextMuted
    CloseBtn.Font = Enum.Font.GothamMedium
    CloseBtn.TextSize = 15
    CloseBtn.AutoButtonColor = false
    CloseBtn.Parent = WindowControls

    -- ➖ ปุ่มพับจอ (Minimize Button)
    local MinBtn = Instance.new("TextButton")
    MinBtn.Name = "Minimize"
    MinBtn.Size = UDim2.new(0, 45, 1, -1)
    MinBtn.BackgroundTransparency = 1
    MinBtn.BackgroundColor3 = GzusUI.Theme.ButtonHover
    MinBtn.Text = "—"
    MinBtn.TextColor3 = GzusUI.Theme.TextMuted
    MinBtn.Font = Enum.Font.GothamMedium
    MinBtn.TextSize = 15
    MinBtn.AutoButtonColor = false
    MinBtn.Parent = WindowControls

    -- 🌟 เอฟเฟกต์ตอนชี้เมาส์ (Hover Effects)
    CloseBtn.MouseEnter:Connect(function()
        GzusUI:Tween(CloseBtn, {BackgroundTransparency = 0, TextColor3 = Color3.fromRGB(255, 255, 255)}, 0.2)
    end)
    CloseBtn.MouseLeave:Connect(function()
        GzusUI:Tween(CloseBtn, {BackgroundTransparency = 1, TextColor3 = GzusUI.Theme.TextMuted}, 0.2)
    end)

    MinBtn.MouseEnter:Connect(function()
        GzusUI:Tween(MinBtn, {BackgroundTransparency = 0, TextColor3 = Color3.fromRGB(255, 255, 255)}, 0.2)
    end)
    MinBtn.MouseLeave:Connect(function()
        GzusUI:Tween(MinBtn, {BackgroundTransparency = 1, TextColor3 = GzusUI.Theme.TextMuted}, 0.2)
    end)

    -- 🌟 ระบบทำงานของปุ่ม
    local isMinimized = false
    MinBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        if isMinimized then
            -- พับจอ (ให้ความสูงเหลือแค่ 45 เท่ากับ Topbar)
            GzusUI:Tween(MainFrame, {Size = UDim2.new(0, Config.Size.X.Offset, 0, 45)}, 0.5)
        else
            -- กางจอออก
            GzusUI:Tween(MainFrame, {Size = Config.Size}, 0.5)
        end
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        -- แอนิเมชันปิดจอสุดหรู
        GzusUI:Tween(MainFrame, {Size = UDim2.new(0, Config.Size.X.Offset, 0, 0), BackgroundTransparency = 1}, 0.4)
        GzusUI:Tween(Shadow, {ImageTransparency = 1}, 0.3)
        GzusUI:Tween(TitleLabel, {TextTransparency = 1}, 0.2)
        GzusUI:Tween(SubTitleLabel, {TextTransparency = 1}, 0.2)
        
        task.delay(0.4, function()
            ScreenGui:Destroy()
        end)
    end)

    -- ==========================================
    -- ⌨️ 5. ระบบ Toggle UI (ซ่อน/โชว์ ด้วยปุ่มลัด)
    -- ==========================================
    local isHidden = false
    UserInputService.InputBegan:Connect(function(Input, gameProcessed)
        if not gameProcessed and Input.KeyCode == Config.ToggleKey then
            isHidden = not isHidden
            if isHidden then
                -- ซ่อน UI (หดตัวลง)
                GzusUI:Tween(MainFrame, {Size = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 1}, 0.4)
                GzusUI:Tween(Shadow, {ImageTransparency = 1}, 0.3)
                for _, obj in pairs(MainFrame:GetDescendants()) do
                    if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                        GzusUI:Tween(obj, {TextTransparency = 1}, 0.2)
                    elseif obj:IsA("Frame") and obj.Name ~= "MainFrame" then
                        GzusUI:Tween(obj, {BackgroundTransparency = 1}, 0.2)
                    end
                end
            else
                -- โชว์ UI (เด้งกลับมา)
                GzusUI:Tween(MainFrame, {Size = isMinimized and UDim2.new(0, Config.Size.X.Offset, 0, 45) or Config.Size, BackgroundTransparency = 0}, 0.5, Enum.EasingStyle.Back)
                GzusUI:Tween(Shadow, {ImageTransparency = 0.4}, 0.5)
                for _, obj in pairs(MainFrame:GetDescendants()) do
                    if obj:IsA("TextLabel") and obj.Name == "Title" then
                        GzusUI:Tween(obj, {TextTransparency = 0}, 0.3)
                    elseif obj:IsA("TextLabel") and obj.Name == "SubTitle" then
                        GzusUI:Tween(obj, {TextTransparency = 0}, 0.3)
                    elseif obj:IsA("TextButton") and (obj.Name == "Close" or obj.Name == "Minimize") then
                        GzusUI:Tween(obj, {TextTransparency = 0}, 0.3)
                    elseif obj.Name == "Divider" then
                        GzusUI:Tween(obj, {BackgroundTransparency = 0}, 0.3)
                    end
                end
            end
        end
    end)

    -- 6. ระบบลากจอแบบสมูท (Smooth Dragging)
    local Dragging = false
    local DragInput
    local DragStart
    local StartPosition

    Topbar.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = Input.Position
            StartPosition = MainFrame.Position

            Input.Changed:Connect(function()
                if Input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                end
            end)
        end
    end)

    Topbar.InputChanged:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
            DragInput = Input
        end
    end)

    UserInputService.InputChanged:Connect(function(Input)
        if Input == DragInput and Dragging then
            local Delta = Input.Position - DragStart
            GzusUI:Tween(MainFrame, {Position = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)}, 0.1)
        end
    end)
    
    Window.Container = MainFrame
    return Window
end

return GzusUI
